{
  "name": "@org/components",
  "version": "0.0.1",
  "files": [
    "dist",
    "global.d.ts"
  ],
  "type": "module",
  "sideEffects": [
    "./dist/*.css",
    "./dist/index.esm.js",
    "./dist/index.umd.js"
  ],
  "main": "dist/index.js",
  "module": "./dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./dist/*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "require": "./dist/*.js"
    },
    "./global.d.ts": "./global.d.ts",
    "./global": "./global.d.ts",
    "./package.json": "./package.json",
    "./dist/index.esm.js": "./dist/index.esm.js",
    "./dist/index.umd.js": "./dist/index.umd.js"
  },
  "scripts": {
    "docs:dev": "vp dev docs",
    "docs:preview": "vp preview docs",
    "test:unit": "vp test",
    "docs:build": "vp build docs",
    "type-check": "vue-tsc --build",
    "build:comp": "vp build --config vite.build.config.ts",
    "build:esm": "vp build --config vite.esm.config.ts",
    "build:umd": "vp build --config vite.umd.config.ts",
    "build": "run-s build:comp build:esm build:umd",
    "prepare": "vp config",
    "fmt": "vp fmt",
    "lint": "vp check --fix"
  },
  "dependencies": {
    "@antdv-next/icons": "^1.0.5",
    "@vueuse/core": "^14.2.1",
